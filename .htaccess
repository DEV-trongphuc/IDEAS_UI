# BEGIN WebP Redirection Rules
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTP_ACCEPT} image/webp
  RewriteCond %{DOCUMENT_ROOT}/$1.webp -f
  RewriteRule ^(wp-content/uploads/.*)\.(jpe?g|png)$ $1.webp [T=image/webp,E=accept:1,L]
</IfModule>
Header append Vary Accept env=REDIRECT_accept
# END WebP Redirection Rules

# ── Custom rewrites (phải đặt TRƯỚC block WordPress) ──────────────
<IfModule mod_rewrite.c>
RewriteEngine On

# Route search queries on homepage (Vietnamese & English) to WordPress index.php immediately
RewriteCond %{THE_REQUEST} [?&]s=
RewriteRule ^/?(en/?)?$ /index.php [L]

# Catch search queries that were rewritten to index.html (VI or EN) and redirect back to WordPress
RewriteCond %{THE_REQUEST} [?&]s=
RewriteRule ^/?wp-content/new_public/LANDINGPAGE_MBA/(en/)?index\.html$ /index.php [L,NC]



# Redirect common-assets to the active theme folder to use only one directory
RewriteCond %{REQUEST_URI} !^/wp-content/themes/LANDINGPAGE_MBA/common-assets/
RewriteRule ^(common-assets)/(.*)$ /wp-content/themes/LANDINGPAGE_MBA/common-assets/$2 [L,NC]

# Route other assets (homepage-assets, assets, salekit) to physical new_public directory
RewriteCond %{REQUEST_URI} !^/wp-content/new_public/LANDINGPAGE_MBA/
RewriteRule ^(homepage-assets|assets|salekit)/(.*)$ /wp-content/new_public/LANDINGPAGE_MBA/$1/$2 [L,NC]

# --- 1. REDIRECTS (301) to Clean URLs ---

# Redirect su-kien to dong-su-kien
RewriteRule ^su-kien/?$ /dong-su-kien [R=301,L,NC]

# Redirect direct access to physical Vietnamese .html files under wp-content
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^/?wp-content/new_public/LANDINGPAGE_MBA/(mba|mscai|emba|bba|fullbba|mbainai|dual-dba|dat-lich)\.html$ /$1 [R=301,L,NC]

# Redirect direct access to physical English .html files under wp-content
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^/?wp-content/new_public/LANDINGPAGE_MBA/en/(mba|mscai|emba|bba|fullbba|mbainai|dual-dba|dat-lich)\.html$ /en/$1 [R=301,L,NC]

# Redirect direct access to physical English index.html under wp-content
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^/?wp-content/new_public/LANDINGPAGE_MBA/en/index\.html$ /en [R=301,L,NC]

# Redirect direct access to physical Vietnamese index.html under wp-content to root /
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^/?wp-content/new_public/LANDINGPAGE_MBA/index\.html$ / [R=301,L,NC]

# Redirect direct access to root-level Vietnamese .html files to clean URLs
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^(mba|mscai|emba|bba|fullbba|mbainai|dual-dba|dat-lich)\.html$ /$1 [R=301,L,NC]

# Redirect direct access to root-level English/legacy .html files to clean URLs
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^(mba|mscai|emba|bba|fullbba|mbainai|bba)-en\.html$ /en/$1 [R=301,L,NC]
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^index-en\.html$ /en [R=301,L,NC]
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^dual-dba-estiam-rb-en$ /en/dual-dba-estiam-rb [R=301,L,NC]

# Redirect legacy/portal CTA Vietnamese URLs to clean URLs
RewriteRule ^swiss-umef-online-mba/?$ /mba [R=301,L,NC]
RewriteRule ^swiss-umef-executive-mba/?$ /emba [R=301,L,NC]
RewriteRule ^swiss-umef-msc-ai/?$ /mscai [R=301,L,NC]
RewriteRule ^swiss-umef-top-up-bba/?$ /bba [R=301,L,NC]

# Redirect legacy/portal CTA English URLs to clean URLs
RewriteRule ^swiss-umef-online-mba-en/?$ /en/mba [R=301,L,NC]
RewriteRule ^swiss-umef-executive-mba-en/?$ /en/emba [R=301,L,NC]
RewriteRule ^swiss-umef-msc-ai-en/?$ /en/mscai [R=301,L,NC]
RewriteRule ^swiss-umef-topup-bba-en/?$ /en/bba [R=301,L,NC]


# --- 2. INTERNAL REWRITES (Silently map clean URLs to physical files) ---

# Vietnamese clean URLs
RewriteCond %{THE_REQUEST} ![?&]s=
RewriteRule ^$ /wp-content/new_public/LANDINGPAGE_MBA/index.html [L]
RewriteRule ^mba/?$ /wp-content/new_public/LANDINGPAGE_MBA/mba.html [L]
RewriteRule ^msc-?ai/?$ /wp-content/new_public/LANDINGPAGE_MBA/mscai.html [L,NC]
RewriteRule ^emba/?$ /wp-content/new_public/LANDINGPAGE_MBA/emba.html [L]
RewriteRule ^bba/?$ /wp-content/new_public/LANDINGPAGE_MBA/bba.html [L]
RewriteRule ^fullbba/?$ /wp-content/new_public/LANDINGPAGE_MBA/fullbba.html [L]
RewriteRule ^(mba-in-ai|mbainai)/?$ /wp-content/new_public/LANDINGPAGE_MBA/mbainai.html [L,NC]
RewriteRule ^dual-dba(-estiam-rb)?/?$ /wp-content/new_public/LANDINGPAGE_MBA/dual-dba.html [L,NC]
RewriteRule ^dat-lich/?$ /wp-content/new_public/LANDINGPAGE_MBA/dat-lich.html [L]

# English clean URLs
RewriteCond %{THE_REQUEST} ![?&]s=
RewriteRule ^en/?$ /wp-content/new_public/LANDINGPAGE_MBA/en/index.html [L]
RewriteRule ^en/mba/?$ /wp-content/new_public/LANDINGPAGE_MBA/en/mba.html [L]
RewriteRule ^en/msc-?ai/?$ /wp-content/new_public/LANDINGPAGE_MBA/en/mscai.html [L,NC]
RewriteRule ^en/emba/?$ /wp-content/new_public/LANDINGPAGE_MBA/en/emba.html [L]
RewriteRule ^en/bba/?$ /wp-content/new_public/LANDINGPAGE_MBA/en/bba.html [L]
RewriteRule ^en/fullbba/?$ /wp-content/new_public/LANDINGPAGE_MBA/en/fullbba.html [L]
RewriteRule ^en/(mba-in-ai|mbainai)/?$ /wp-content/new_public/LANDINGPAGE_MBA/en/mbainai.html [L,NC]
RewriteRule ^en/dual-dba(-estiam-rb)?/?$ /wp-content/new_public/LANDINGPAGE_MBA/en/dual-dba.html [L,NC]
RewriteRule ^en/dat-lich/?$ /wp-content/new_public/LANDINGPAGE_MBA/en/dat-lich.html [L]

# Route riêng cho landing xét duyệt (giữ nguyên rule cũ)
RewriteRule ^xet-duyet-ho-so-truc-tuyen/?$ /wp-content/index.html [L]

# Route cho salekit portal
RewriteRule ^salekit$ /salekit/ [R=301,L,NC]
RewriteRule ^salekit/$ /wp-content/new_public/LANDINGPAGE_MBA/salekit/index.html [L]
</IfModule>
# ────────────────────────────────────────────────────────────────────

# BEGIN WordPress
# Các nội dung nằm giữa "BEGIN WordPress" và "END WordPress" được tạo ra tự động, và chỉ nên được thay đổi thông qua các filter của WordPress. Mọi thay đổi tới thành phần này có thể sẽ bị mất và ghi đè.
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
RewriteBase /
RewriteRule ^index\.php$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.php [L]
</IfModule>

# END WordPress

# BEGIN Performance Tuning
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>
# END Performance Tuning